# BMS API Server Configuration
PORT=5000

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bms_db

# JWT Configuration
# Ensure these secrets are long, complex, and secure in production environments
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Vercel Blob Storage (required for photo uploads in production)
# Get this from: Vercel Dashboard → Storage → Blob → Your Store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_********

# CORS — set to your deployed frontend URL in production (e.g., https://bms.vercel.app)
# Leave as * for local development
ALLOWED_ORIGIN=*
